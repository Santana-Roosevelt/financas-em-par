// ============================================================
// Schema Prisma — Finanças em Par
// Banco de dados: PostgreSQL
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USUÁRIOS
// ============================================================
model Usuario {
  id           String   @id @default(uuid())
  nome         String
  email        String   @unique
  senhaHash    String?  @map("senha_hash")
  avatarUrl    String?  @map("avatar_url")
  googleId     String?  @unique @map("google_id")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Relações
  membrosDoCasal   MembroDoCasal[]
  transacoes       Transacao[]
  metasIndividuais Meta[]         @relation("MetaUsuario")

  @@map("usuarios")
}

// ============================================================
// CASAL
// ============================================================
model Casal {
  id           String   @id @default(uuid())
  nome         String
  codigoConvite String  @unique @map("codigo_convite")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  // Relações
  membros      MembroDoCasal[]
  categorias   Categoria[]
  transacoes   Transacao[]
  metas        Meta[]

  @@map("casais")
}

// ============================================================
// MEMBROS DO CASAL (relação usuário <-> casal)
// ============================================================
model MembroDoCasal {
  id       String   @id @default(uuid())
  papel    PapelMembro @default(PARCEIRO)
  entrou   DateTime @default(now())

  // Relações
  casalId  String   @map("casal_id")
  casal    Casal    @relation(fields: [casalId], references: [id], onDelete: Cascade)

  usuarioId String  @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([casalId, usuarioId])
  @@map("membros_do_casal")
}

// ============================================================
// CATEGORIAS
// ============================================================
model Categoria {
  id       String         @id @default(uuid())
  nome     String
  icone    String         @default("💰")
  cor      String         @default("#6366f1")
  tipo     TipoTransacao
  padrao   Boolean        @default(false) // true = categoria do sistema

  // Relações
  casalId  String?        @map("casal_id")
  casal    Casal?         @relation(fields: [casalId], references: [id], onDelete: Cascade)

  transacoes Transacao[]

  @@map("categorias")
}

// ============================================================
// TRANSAÇÕES
// ============================================================
model Transacao {
  id          String        @id @default(uuid())
  valor       Decimal       @db.Decimal(10, 2)
  tipo        TipoTransacao
  escopo      EscopoFinanceiro
  descricao   String?
  data        DateTime      @db.Date
  criadoEm   DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime    @updatedAt @map("atualizado_em")

  // Relações
  casalId     String        @map("casal_id")
  casal       Casal         @relation(fields: [casalId], references: [id], onDelete: Cascade)

  usuarioId   String        @map("usuario_id")
  usuario     Usuario       @relation(fields: [usuarioId], references: [id])

  categoriaId String        @map("categoria_id")
  categoria   Categoria     @relation(fields: [categoriaId], references: [id])

  @@map("transacoes")
}

// ============================================================
// METAS FINANCEIRAS
// ============================================================
model Meta {
  id            String           @id @default(uuid())
  titulo        String
  valorAlvo     Decimal          @db.Decimal(10, 2) @map("valor_alvo")
  valorAtual    Decimal          @db.Decimal(10, 2) @default(0) @map("valor_atual")
  escopo        EscopoFinanceiro
  icone         String           @default("🎯")
  cor           String           @default("#10b981")
  prazo         DateTime?        @db.Date
  status        StatusMeta       @default(ATIVA)
  criadoEm     DateTime         @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt @map("atualizado_em")

  // Relações
  casalId       String           @map("casal_id")
  casal         Casal            @relation(fields: [casalId], references: [id], onDelete: Cascade)

  usuarioId     String?          @map("usuario_id") // null = meta conjunta
  usuario       Usuario?         @relation("MetaUsuario", fields: [usuarioId], references: [id])

  @@map("metas")
}

// ============================================================
// ENUMS
// ============================================================
enum TipoTransacao {
  RECEITA
  DESPESA

  @@map("tipo_transacao")
}

enum EscopoFinanceiro {
  INDIVIDUAL
  CONJUNTO

  @@map("escopo_financeiro")
}

enum PapelMembro {
  DONO
  PARCEIRO

  @@map("papel_membro")
}

enum StatusMeta {
  ATIVA
  CONCLUIDA
  CANCELADA

  @@map("status_meta")
}
